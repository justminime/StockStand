# ─── Google OAuth (Wave 3) ────────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Auth.js v5 secret — generated with: openssl rand -base64 32
# (NEXTAUTH_SECRET is also accepted for backwards compatibility)
AUTH_SECRET=

# ─── Vercel Postgres / Neon (Wave 3) ─────────────────────────────────────────
# Auto-set when you link a Vercel Postgres (Neon) database to the project.
# Run db/migrations/001_game_users.sql after provisioning the DB.
# Local dev: leave blank to skip DB sync (localStorage-only mode)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ─── Vercel KV / Upstash Redis (stock price cache) ───────────────────────────
# Auto-set when you link a KV store to the project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── Stock API ────────────────────────────────────────────────────────────────
# Local development: use 'mock' to skip Yahoo Finance and return fallback prices
# Production: use 'yahoo'
STOCK_API_PROVIDER=mock

# ─── COPPA Cron Guard ─────────────────────────────────────────────────────────
# Generated with: openssl rand -base64 32
# Vercel Cron sends this as "Authorization: Bearer <CRON_SECRET>"
CRON_SECRET=

# ─── Analytics (Wave 5+) ─────────────────────────────────────────────────────
# Only loaded for adult users (COPPA compliance — never for teens/children)
# Value: your Plausible site domain — must match what you registered in Plausible dashboard
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=stockstand.shifth.com
