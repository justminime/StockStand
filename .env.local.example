# ─── Google OAuth (Wave 5) ───────────────────────────────────────────────────
# From: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Generated with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Vercel Postgres / Neon (Wave 5) ─────────────────────────────────────────
# Auto-set when you link a Vercel Postgres database to the project
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# ─── Vercel KV / Upstash Redis (Wave 2) ──────────────────────────────────────
# Auto-set when you link a KV store to the project
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── Stock API (Wave 2) ───────────────────────────────────────────────────────
# Local development: use 'mock' to skip Yahoo Finance and return fallback prices
# Production: use 'yahoo'
STOCK_API_PROVIDER=mock

# ─── COPPA Cron Guard (Wave 6) ───────────────────────────────────────────────
# Generated with: openssl rand -base64 32
# Vercel Cron sends this as "Authorization: Bearer <CRON_SECRET>"
CRON_SECRET=

# ─── Analytics (Wave 6) ──────────────────────────────────────────────────────
# Only loaded for adult users (COPPA compliance — never for teens/children)
# Value: your Plausible site domain, e.g. "stockstand.vercel.app"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
